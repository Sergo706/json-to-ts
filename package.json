{
  "name": "@riavzon/json-to-ts",
  "version": "1.0.0",
  "type": "module",
  "author": "Sergio contact@riavzon.com",
  "license": "MIT",
  "repository": {
      "type": "git",
      "url": "https://github.com/Sergo706/json-to-ts"
  },
  "bugs": {
      "url": "https://github.com/Sergo706/json-to-ts/issues"
  },
  "keywords": [
    "json",
    "typescript",
    "interface",
    "generator",
    "converter",
    "types",
    "json-to-ts",
    "literal-types",
    "esm"
  ],
  "homepage": "https://github.com/Sergo706/json-to-ts#readme",
  "description": "Convert json object to typescript interfaces",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "test": "npx tsx --test test/*.spec.ts",
    "build": "tsup",
    "lint": "eslint . --fix"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
